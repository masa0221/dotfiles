# シークレット設定のテンプレート
# このファイルをコピーして ~/.zsh/secrets.zsh として配置してください
# （リポジトリには含めません）
#
#   cp zsh/secrets.zsh.example ~/.zsh/secrets.zsh
#   vim ~/.zsh/secrets.zsh
#
# ⚠️ ~/.zsh/secrets.zsh は .gitignore に含まれています

# Homebrew GitHub API Token
# https://github.com/settings/tokens で生成
# export HOMEBREW_GITHUB_API_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
